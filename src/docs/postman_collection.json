{
  "info": {
    "name": "FlowPilot API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"Karan\",\"email\":\"karan@example.com\",\"password\":\"Password123!\",\"organizationName\":\"FlowPilot\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\":\"karan@example.com\",\"password\":\"Password123!\"}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh-token",
            "body": { "mode": "raw", "raw": "{\"refreshToken\":\"{{refreshToken}}\"}" }
          }
        }
      ]
    },
    {
      "name": "CRM",
      "item": [
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/leads",
            "body": { "mode": "raw", "raw": "{\"name\":\"Acme Buyer\",\"email\":\"buyer@acme.com\",\"company\":\"Acme\",\"status\":\"new\",\"value\":5000}" }
          }
        },
        {
          "name": "List Leads",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "url": "{{baseUrl}}/leads?page=1&limit=20&search=acme"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/projects",
            "body": { "mode": "raw", "raw": "{\"name\":\"Website Relaunch\",\"status\":\"active\"}" }
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Chat",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/ai/chat",
            "body": { "mode": "raw", "raw": "{\"message\":\"Summarize this week's operational priorities\"}" }
          }
        }
      ]
    }
  ]
}
