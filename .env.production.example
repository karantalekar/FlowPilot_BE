NODE_ENV=production
PORT=5000
APP_NAME=FlowPilot
CLIENT_URL=https://flow-pilot-one-bay.vercel.app
API_BASE_URL=https://your-backend-domain.example.com

MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/flowpilot
REDIS_URL=redis://default:password@host:port
REDIS_ENABLED=true

JWT_ACCESS_SECRET=replace-with-a-unique-random-secret-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-a-unique-random-secret-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

COOKIE_SECRET=replace-with-a-unique-random-secret-at-least-32-characters
BCRYPT_SALT_ROUNDS=12

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-backend-domain.example.com/api/v1/auth/google/callback

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_BUSINESS=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=no-reply@example.com

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20
